#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Get the current branch name
current_branch=$(git symbolic-ref --short HEAD)

# Define protected branches
protected_branches=("main" "staging", "prod")

# Check if current branch is in protected branches
for branch in "${protected_branches[@]}"; do
  if [ "$current_branch" = "$branch" ]; then
    echo "❌ ERROR: Direct push to '$branch' branch is not allowed!"
    echo "Please create a feature branch and submit a pull request instead."
    echo ""
    echo "To create a new branch, run:"
    echo "  git checkout -b feature/your-feature-name"
    exit 1
  fi
done